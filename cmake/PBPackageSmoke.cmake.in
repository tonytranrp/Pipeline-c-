set(PB_PACKAGE_SMOKE_SOURCE_DIR "@PROJECT_SOURCE_DIR@")
set(PB_PACKAGE_SMOKE_BINARY_DIR "@PROJECT_BINARY_DIR@")
set(PB_PACKAGE_SMOKE_INSTALL_DIR "${PB_PACKAGE_SMOKE_BINARY_DIR}/package-smoke/install")
set(PB_PACKAGE_SMOKE_CPACK_DIR "${PB_PACKAGE_SMOKE_BINARY_DIR}/package-smoke/cpack")
set(PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR "${PB_PACKAGE_SMOKE_BINARY_DIR}/package-smoke/consumer")
set(PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR "${PB_PACKAGE_SMOKE_BINARY_DIR}/package-smoke/consumer-build")
if(NOT DEFINED PB_PACKAGE_SMOKE_CONFIG)
  set(PB_PACKAGE_SMOKE_CONFIG "@CMAKE_BUILD_TYPE@")
endif()

if(DEFINED PB_PACKAGE_SMOKE_CONFIG AND NOT PB_PACKAGE_SMOKE_CONFIG STREQUAL "")
  set(PB_PACKAGE_SMOKE_BUILD_CONFIG "${PB_PACKAGE_SMOKE_CONFIG}")
endif()

file(REMOVE_RECURSE
  "${PB_PACKAGE_SMOKE_INSTALL_DIR}"
  "${PB_PACKAGE_SMOKE_CPACK_DIR}"
  "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}"
  "${PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR}"
)
file(MAKE_DIRECTORY
  "${PB_PACKAGE_SMOKE_CPACK_DIR}"
  "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}"
)

set(PB_PACKAGE_SMOKE_INSTALL_ARGS
  "@CMAKE_COMMAND@" --install "${PB_PACKAGE_SMOKE_BINARY_DIR}"
  --prefix "${PB_PACKAGE_SMOKE_INSTALL_DIR}"
)
if(DEFINED PB_PACKAGE_SMOKE_BUILD_CONFIG AND NOT PB_PACKAGE_SMOKE_BUILD_CONFIG STREQUAL "")
  list(APPEND PB_PACKAGE_SMOKE_INSTALL_ARGS --config "${PB_PACKAGE_SMOKE_BUILD_CONFIG}")
endif()

execute_process(
  COMMAND ${PB_PACKAGE_SMOKE_INSTALL_ARGS}
  RESULT_VARIABLE PB_PACKAGE_SMOKE_INSTALL_RESULT
  OUTPUT_VARIABLE PB_PACKAGE_SMOKE_INSTALL_OUTPUT
  ERROR_VARIABLE PB_PACKAGE_SMOKE_INSTALL_ERROR
)
if(NOT PB_PACKAGE_SMOKE_INSTALL_RESULT EQUAL 0)
  message(FATAL_ERROR
    "pipebuilder install step failed.\n"
    "stdout:\n${PB_PACKAGE_SMOKE_INSTALL_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_INSTALL_ERROR}"
  )
endif()

file(WRITE "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}/CMakeLists.txt" [=[
cmake_minimum_required(VERSION 3.23)
project(pipebuilder_package_smoke LANGUAGES CXX)

find_package(pipebuilder CONFIG REQUIRED)

foreach(required_target IN ITEMS pb::core pb::runtime pb::pipeline)
  if(NOT TARGET ${required_target})
    message(FATAL_ERROR "pipebuilder package did not define ${required_target}")
  endif()
endforeach()

# Keep these as independent executables so each installed target and compatibility
# alias must provide its own usage requirements to a clean consumer.
add_executable(pipebuilder_core_target_smoke core_target.cpp)
target_compile_features(pipebuilder_core_target_smoke PRIVATE cxx_std_20)
target_link_libraries(pipebuilder_core_target_smoke PRIVATE pb::core)

add_executable(pipebuilder_runtime_target_smoke runtime_target.cpp)
target_compile_features(pipebuilder_runtime_target_smoke PRIVATE cxx_std_20)
target_link_libraries(pipebuilder_runtime_target_smoke PRIVATE pb::runtime)

add_executable(pipebuilder_pipeline_alias_smoke pipeline_alias.cpp)
target_compile_features(pipebuilder_pipeline_alias_smoke PRIVATE cxx_std_20)
target_link_libraries(pipebuilder_pipeline_alias_smoke PRIVATE pb::pipeline)
]=])

file(WRITE "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}/core_target.cpp" [=[
#include <pb/core/validate.hpp>

int main() {
  using Pipeline = pb::core::from<int>::to<int>;
  static_assert(pb::core::ValidPipeline<Pipeline>);
  return 0;
}
]=])

file(WRITE "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}/runtime_target.cpp" [=[
#include <pb/runtime/error.hpp>

#include <string>

int main() {
  pb::runtime::error failure{.stage = {.key = "consumer", .name = "consumer"},
                             .category = pb::runtime::error_category::stage_failure,
                             .message = "package consumer linked pb::runtime"};
  if (!pb::runtime::has_stage(failure)) {
    return 1;
  }
  return pb::runtime::describe(failure).find("package consumer") != std::string::npos ? 0 : 1;
}
]=])

file(WRITE "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}/pipeline_alias.cpp" [=[
#include <pb/pipeline.hpp>

struct Increment {
  using input_type = int;
  using output_type = int;

  static constexpr auto stage_name() noexcept { return "increment"; }

  int operator()(int value) const { return value + 1; }
};

int main() {
  using Pipeline = pb::from<int>::then<Increment>::to<int>;
  static_assert(pb::ValidPipeline<Pipeline>);

  auto engine = pb::compile<Pipeline>(pb::runtime::sequential{});
  // If the installed package leaks this project's warning policy (especially
  // -Werror) through its exported interface targets, this downstream consumer
  // becomes a package-smoke failure under the warnings-as-errors preset.
  int intentionally_unused_for_package_warning_leak_check = 0;
  return engine.run(41) == 42 ? 0 : 1;
}
]=])

set(PB_PACKAGE_SMOKE_CONFIGURE_ARGS
  -S "${PB_PACKAGE_SMOKE_CONSUMER_SOURCE_DIR}"
  -B "${PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR}"
  -G "@CMAKE_GENERATOR@"
  "-DCMAKE_PREFIX_PATH=${PB_PACKAGE_SMOKE_INSTALL_DIR}"
  "-DCMAKE_CXX_COMPILER=@CMAKE_CXX_COMPILER@"
)
if(NOT "@CMAKE_BUILD_TYPE@" STREQUAL "")
  list(APPEND PB_PACKAGE_SMOKE_CONFIGURE_ARGS "-DCMAKE_BUILD_TYPE=@CMAKE_BUILD_TYPE@")
endif()

execute_process(
  COMMAND "@CMAKE_COMMAND@" ${PB_PACKAGE_SMOKE_CONFIGURE_ARGS}
  RESULT_VARIABLE PB_PACKAGE_SMOKE_CONFIGURE_RESULT
  OUTPUT_VARIABLE PB_PACKAGE_SMOKE_CONFIGURE_OUTPUT
  ERROR_VARIABLE PB_PACKAGE_SMOKE_CONFIGURE_ERROR
)
if(NOT PB_PACKAGE_SMOKE_CONFIGURE_RESULT EQUAL 0)
  message(FATAL_ERROR
    "pipebuilder package consumer configure failed.\n"
    "stdout:\n${PB_PACKAGE_SMOKE_CONFIGURE_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_CONFIGURE_ERROR}"
  )
endif()

set(PB_PACKAGE_SMOKE_BUILD_ARGS --build "${PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR}")
if(DEFINED PB_PACKAGE_SMOKE_BUILD_CONFIG AND NOT PB_PACKAGE_SMOKE_BUILD_CONFIG STREQUAL "")
  list(APPEND PB_PACKAGE_SMOKE_BUILD_ARGS --config "${PB_PACKAGE_SMOKE_BUILD_CONFIG}")
endif()

execute_process(
  COMMAND "@CMAKE_COMMAND@" ${PB_PACKAGE_SMOKE_BUILD_ARGS}
  RESULT_VARIABLE PB_PACKAGE_SMOKE_BUILD_RESULT
  OUTPUT_VARIABLE PB_PACKAGE_SMOKE_BUILD_OUTPUT
  ERROR_VARIABLE PB_PACKAGE_SMOKE_BUILD_ERROR
)
if(NOT PB_PACKAGE_SMOKE_BUILD_RESULT EQUAL 0)
  message(FATAL_ERROR
    "pipebuilder package consumer build failed.\n"
    "stdout:\n${PB_PACKAGE_SMOKE_BUILD_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_BUILD_ERROR}"
  )
endif()

set(PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES)
foreach(PB_PACKAGE_SMOKE_EXECUTABLE_NAME IN ITEMS
  pipebuilder_core_target_smoke
  pipebuilder_runtime_target_smoke
  pipebuilder_pipeline_alias_smoke
)
  set(PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES)
  if(DEFINED PB_PACKAGE_SMOKE_BUILD_CONFIG AND NOT PB_PACKAGE_SMOKE_BUILD_CONFIG STREQUAL "")
    list(APPEND PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES
      "${PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR}/${PB_PACKAGE_SMOKE_BUILD_CONFIG}/${PB_PACKAGE_SMOKE_EXECUTABLE_NAME}@CMAKE_EXECUTABLE_SUFFIX@"
    )
  endif()
  list(APPEND PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES
    "${PB_PACKAGE_SMOKE_CONSUMER_BINARY_DIR}/${PB_PACKAGE_SMOKE_EXECUTABLE_NAME}@CMAKE_EXECUTABLE_SUFFIX@"
  )

  set(PB_PACKAGE_SMOKE_EXECUTABLE)
  foreach(PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATE IN LISTS PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES)
    if(EXISTS "${PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATE}")
      set(PB_PACKAGE_SMOKE_EXECUTABLE "${PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATE}")
      break()
    endif()
  endforeach()

  if(NOT PB_PACKAGE_SMOKE_EXECUTABLE)
    message(FATAL_ERROR
      "pipebuilder package consumer executable ${PB_PACKAGE_SMOKE_EXECUTABLE_NAME} was not found. Checked: ${PB_PACKAGE_SMOKE_EXECUTABLE_CANDIDATES}"
    )
  endif()

  execute_process(
    COMMAND "${PB_PACKAGE_SMOKE_EXECUTABLE}"
    RESULT_VARIABLE PB_PACKAGE_SMOKE_RUN_RESULT
    OUTPUT_VARIABLE PB_PACKAGE_SMOKE_RUN_OUTPUT
    ERROR_VARIABLE PB_PACKAGE_SMOKE_RUN_ERROR
  )
  if(NOT PB_PACKAGE_SMOKE_RUN_RESULT EQUAL 0)
    message(FATAL_ERROR
      "pipebuilder package consumer ${PB_PACKAGE_SMOKE_EXECUTABLE_NAME} run failed.\n"
      "stdout:\n${PB_PACKAGE_SMOKE_RUN_OUTPUT}\n"
      "stderr:\n${PB_PACKAGE_SMOKE_RUN_ERROR}"
    )
  endif()
endforeach()

execute_process(
  COMMAND "@CMAKE_CPACK_COMMAND@"
    -G TGZ
    --config "${PB_PACKAGE_SMOKE_BINARY_DIR}/CPackConfig.cmake"
    -B "${PB_PACKAGE_SMOKE_CPACK_DIR}"
  RESULT_VARIABLE PB_PACKAGE_SMOKE_CPACK_RESULT
  OUTPUT_VARIABLE PB_PACKAGE_SMOKE_CPACK_OUTPUT
  ERROR_VARIABLE PB_PACKAGE_SMOKE_CPACK_ERROR
)
if(NOT PB_PACKAGE_SMOKE_CPACK_RESULT EQUAL 0)
  message(FATAL_ERROR
    "pipebuilder CPack TGZ generation failed.\n"
    "stdout:\n${PB_PACKAGE_SMOKE_CPACK_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_CPACK_ERROR}"
  )
endif()

file(GLOB PB_PACKAGE_SMOKE_ARCHIVES "${PB_PACKAGE_SMOKE_CPACK_DIR}/*.tar.gz")
list(LENGTH PB_PACKAGE_SMOKE_ARCHIVES PB_PACKAGE_SMOKE_ARCHIVE_COUNT)
if(PB_PACKAGE_SMOKE_ARCHIVE_COUNT LESS 1)
  message(FATAL_ERROR
    "pipebuilder CPack TGZ generation did not produce an archive in ${PB_PACKAGE_SMOKE_CPACK_DIR}.\n"
    "stdout:\n${PB_PACKAGE_SMOKE_CPACK_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_CPACK_ERROR}"
  )
endif()
list(GET PB_PACKAGE_SMOKE_ARCHIVES 0 PB_PACKAGE_SMOKE_ARCHIVE)

execute_process(
  COMMAND "@CMAKE_COMMAND@" -E tar tf "${PB_PACKAGE_SMOKE_ARCHIVE}"
  RESULT_VARIABLE PB_PACKAGE_SMOKE_ARCHIVE_LIST_RESULT
  OUTPUT_VARIABLE PB_PACKAGE_SMOKE_ARCHIVE_LIST_OUTPUT
  ERROR_VARIABLE PB_PACKAGE_SMOKE_ARCHIVE_LIST_ERROR
)
if(NOT PB_PACKAGE_SMOKE_ARCHIVE_LIST_RESULT EQUAL 0)
  message(FATAL_ERROR
    "pipebuilder CPack TGZ archive could not be listed.\n"
    "archive: ${PB_PACKAGE_SMOKE_ARCHIVE}\n"
    "stdout:\n${PB_PACKAGE_SMOKE_ARCHIVE_LIST_OUTPUT}\n"
    "stderr:\n${PB_PACKAGE_SMOKE_ARCHIVE_LIST_ERROR}"
  )
endif()

foreach(PB_PACKAGE_SMOKE_REQUIRED_ENTRY IN ITEMS
  "include/pb/pipeline.hpp"
  "lib/cmake/pipebuilder/pipebuilderConfig.cmake"
  "lib/cmake/pipebuilder/pipebuilderTargets.cmake"
  "lib/libpb_runtime.a"
)
  string(FIND "${PB_PACKAGE_SMOKE_ARCHIVE_LIST_OUTPUT}" "${PB_PACKAGE_SMOKE_REQUIRED_ENTRY}" PB_PACKAGE_SMOKE_REQUIRED_ENTRY_INDEX)
  if(PB_PACKAGE_SMOKE_REQUIRED_ENTRY_INDEX EQUAL -1)
    message(FATAL_ERROR
      "pipebuilder CPack TGZ archive is missing ${PB_PACKAGE_SMOKE_REQUIRED_ENTRY}.\n"
      "archive: ${PB_PACKAGE_SMOKE_ARCHIVE}\n"
      "contents:\n${PB_PACKAGE_SMOKE_ARCHIVE_LIST_OUTPUT}"
    )
  endif()
endforeach()
