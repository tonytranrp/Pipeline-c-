// ─────────────────────────────────────────────────────────────
// Pipeline‑c++ C++20 module interface unit (experimental)
//
// This module provides a curated export surface for the
// Pipeline‑c++ library.  Include the traditional header
// (<pb/pipeline.hpp>) if your toolchain does not yet support
// C++20 modules (MSVC 17.5+, Clang 17+, GCC 15+).
//
// Build example (MSVC):
//   cl /std:c++20 /experimental:module /interface /EHsc ^
//      /I include include/pb/pipeline.mpp
//
// Build example (Clang):
//   clang++ -std=c++20 -fmodules --precompile -I include ^
//           include/pb/pipeline.mpp -o pb.pipeline.pcm
// ─────────────────────────────────────────────────────────────

module;

// Standard‑library headers that the module's exported
// interface depends on.  These are NOT re‑exported; consumers
// must import or include them separately.
#include <concepts>
#include <cstddef>
#include <string>
#include <string_view>
#include <tuple>
#include <type_traits>
#include <utility>
#include <variant>
#include <vector>

// Pull in the entire header‑only library so that all type
// definitions are visible inside the module purview.
#include <pb/pipeline.hpp>

// ── Module purview ───────────────────────────────────────────

export module pb.pipeline;

