{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-ninja",
      "displayName": "Developer Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PB_BUILD_TESTS": "ON",
        "PB_BUILD_EXAMPLES": "ON",
        "PB_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "clang-dev-ninja",
      "displayName": "Clang Developer Debug (Ninja)",
      "inherits": "dev-ninja",
      "binaryDir": "${sourceDir}/build/clang-dev-ninja",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-time-trace",
      "displayName": "Clang Compile-Time Trace",
      "inherits": "clang-dev-ninja",
      "binaryDir": "${sourceDir}/build/clang-time-trace",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "PB_ENABLE_CLANG_TIME_TRACE": "ON"
      }
    },
    {
      "name": "clang-tidy-ninja",
      "displayName": "Clang-Tidy Tooling (Ninja)",
      "inherits": "clang-dev-ninja",
      "binaryDir": "${sourceDir}/build/clang-tidy-ninja",
      "cacheVariables": {
        "PB_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "pch-ninja",
      "displayName": "Precompiled Header Smoke (Ninja)",
      "inherits": "dev-ninja",
      "binaryDir": "${sourceDir}/build/pch-ninja",
      "cacheVariables": {
        "PB_ENABLE_PCH": "ON"
      }
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PB_BUILD_TESTS": "ON",
        "PB_BUILD_EXAMPLES": "ON",
        "PB_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "release-clang-ninja",
      "displayName": "Release Clang (Ninja)",
      "inherits": "release-ninja",
      "binaryDir": "${sourceDir}/build/release-clang-ninja",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "package-dev-ninja",
      "displayName": "Package Debug (Ninja)",
      "inherits": "dev-ninja",
      "binaryDir": "${sourceDir}/build/package-dev-ninja",
      "cacheVariables": {
        "CPACK_GENERATOR": "TGZ"
      }
    },
    {
      "name": "package-release-clang-ninja",
      "displayName": "Package Release Clang (Ninja)",
      "inherits": "release-clang-ninja",
      "binaryDir": "${sourceDir}/build/package-release-clang-ninja",
      "cacheVariables": {
        "CPACK_GENERATOR": "TGZ"
      }
    },
    {
      "name": "bench-dev-ninja",
      "displayName": "Benchmark Smoke Debug (Ninja)",
      "inherits": "dev-ninja",
      "binaryDir": "${sourceDir}/build/bench-dev-ninja",
      "cacheVariables": {
        "PB_BUILD_TESTS": "OFF",
        "PB_BUILD_EXAMPLES": "OFF",
        "PB_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "benchmark-ninja",
      "displayName": "Benchmark Smoke Release (Ninja)",
      "inherits": "release-ninja",
      "binaryDir": "${sourceDir}/build/benchmark-ninja",
      "cacheVariables": {
        "PB_BUILD_EXAMPLES": "OFF",
        "PB_BUILD_TESTS": "OFF",
        "PB_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "warnings-as-errors-ninja",
      "displayName": "Warnings as Errors (Ninja)",
      "inherits": "dev-ninja",
      "binaryDir": "${sourceDir}/build/warnings-as-errors-ninja",
      "cacheVariables": {
        "PB_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-ninja",
      "configurePreset": "dev-ninja"
    },
    {
      "name": "clang-dev-ninja",
      "configurePreset": "clang-dev-ninja"
    },
    {
      "name": "clang-time-trace",
      "configurePreset": "clang-time-trace"
    },
    {
      "name": "clang-tidy-ninja",
      "configurePreset": "clang-tidy-ninja"
    },
    {
      "name": "pch-ninja",
      "configurePreset": "pch-ninja"
    },
    {
      "name": "release-ninja",
      "configurePreset": "release-ninja"
    },
    {
      "name": "release-clang-ninja",
      "configurePreset": "release-clang-ninja"
    },
    {
      "name": "package-dev-ninja",
      "configurePreset": "package-dev-ninja"
    },
    {
      "name": "package-release-clang-ninja",
      "configurePreset": "package-release-clang-ninja"
    },
    {
      "name": "bench-dev-ninja",
      "configurePreset": "bench-dev-ninja"
    },
    {
      "name": "benchmark-ninja",
      "configurePreset": "benchmark-ninja"
    },
    {
      "name": "warnings-as-errors-ninja",
      "configurePreset": "warnings-as-errors-ninja"
    }
  ],
  "testPresets": [
    {
      "name": "dev-ninja",
      "configurePreset": "dev-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-dev-ninja",
      "configurePreset": "clang-dev-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-time-trace",
      "configurePreset": "clang-time-trace",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-tidy-ninja",
      "configurePreset": "clang-tidy-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "pch-ninja",
      "configurePreset": "pch-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-ninja",
      "configurePreset": "release-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-clang-ninja",
      "configurePreset": "release-clang-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "package-dev-ninja",
      "configurePreset": "package-dev-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "package-dev-smoke",
      "configurePreset": "package-dev-ninja",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "label": {
          "include": "package"
        }
      }
    },
    {
      "name": "package-release-clang-ninja",
      "configurePreset": "package-release-clang-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "package-release-clang-smoke",
      "configurePreset": "package-release-clang-ninja",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "label": {
          "include": "package"
        }
      }
    },
    {
      "name": "bench-dev-ninja",
      "configurePreset": "bench-dev-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "benchmark-ninja",
      "configurePreset": "benchmark-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "warnings-as-errors-ninja",
      "configurePreset": "warnings-as-errors-ninja",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
